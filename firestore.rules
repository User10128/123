rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == 'email-control-panel@checkers.page' && 
             request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Artifacts root
    match /artifacts/{appId} {
      
      // Admin collection - ONLY accessible by the developer account
      match /admin/{allPaths=**} {
        allow read, write: if isAdmin();
      }
      
      // Public data - readable by anyone, writable by admin
      match /public/{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
      
      // User specific data
      match /users/{userId} {
        
        // Private data (friends, etc.)
        match /private/{document=**} {
          allow read, write: if isOwner(userId) || isAdmin();
        }

        // Friend Requests
        match /friendRequests/{requestId} {
          allow read, delete, update: if isOwner(userId) || isAdmin();
          allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid;
        }
        
        // Messages/Responses inbox
        match /messages/{messageId} {
          // Users can read their own messages, Admin can write to them
          // Also allow users to send friendship_accepted and friendship_removed notifications
          allow read, delete, update: if isOwner(userId) || isAdmin();
          allow create: if isAdmin() || (
            isAuthenticated() && 
            request.resource.data.fromUid == request.auth.uid &&
            (request.resource.data.type == 'friendship_accepted' || request.resource.data.type == 'friendship_removed')
          );
        }
        
        // Stats
        match /stats/{document=**} {
          allow read: if true; // Stats are public for leaderboard
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
