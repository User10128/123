rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'billlokey@gmail.com' || request.auth.token.email == 'email-control-panel@checkers.page') && 
             request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProfile(data) {
      return ('displayName' in data) && (data.displayName is string && data.displayName.size() <= 50) &&
             data.keys().hasOnly([
               'displayName', 'playerPoints', 'wins', 'losses', 'globalScore',
               'aiEasyScore', 'aiMediumScore', 'aiHardScore', 'badges', 'awards',
               'streak', 'lastStreakDate', 'lastPointsDate', 'dailyPoints',
               'isOnline', 'lastSeen', 'friendCode', 'hiddenFromLeaderboard'
             ]) &&
             (!('playerPoints' in data) || data.playerPoints is number) &&
             (!('wins' in data) || data.wins is number) &&
             (!('losses' in data) || data.losses is number) &&
             (!('globalScore' in data) || data.globalScore is number) &&
             (!('aiEasyScore' in data) || data.aiEasyScore is number) &&
             (!('aiMediumScore' in data) || data.aiMediumScore is number) &&
             (!('aiHardScore' in data) || data.aiHardScore is number) &&
             (!('isOnline' in data) || data.isOnline is bool) &&
             (!('lastSeen' in data) || data.lastSeen is number) &&
             (!('friendCode' in data) || (data.friendCode is string && data.friendCode.size() == 8));
    }

    function isPlayerInGame(gameData) {
      return isAuthenticated() && (gameData.p1.uid == request.auth.uid || (gameData.p2 != null && gameData.p2.uid == request.auth.uid));
    }

    function isValidSocialEvent(data) {
      return data.uid == request.auth.uid &&
             data.userName is string && data.userName.size() <= 50 &&
             data.text is string && data.text.size() <= 280 &&
             data.timestamp is number;
    }

    // Artifacts root
    match /artifacts/{appId} {
      
      // Admin collection
      match /admin/{allPaths=**} {
        allow read, write: if isAdmin();
      }
      
      // Public data
      match /public/data/profiles/{userId} {
        allow read: if true;
        allow write: if isOwner(userId) && isValidProfile(request.resource.data);
        allow write: if isAdmin();
      }

      match /public/data/friendCodes/{code} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
        allow write: if isAdmin();
      }

      match /public/data/emails/{email} {
        allow read: if isAdmin();
        allow write: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
        allow write: if isAdmin();
      }

      match /public/data/socialFeed/{eventId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidSocialEvent(request.resource.data);
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
        allow update: if isAdmin();
      }

      match /public/data/matchmaking/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
      
      // User specific data
      match /users/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        
        match /private/{document=**} {
          allow read, write: if isOwner(userId) || isAdmin();
        }

        match /friendRequests/{requestId} {
          allow read, delete: if isOwner(userId) || isAdmin();
          allow create: if isAuthenticated();
        }

        match /invites/{inviteId} {
          allow read, delete: if isOwner(userId) || isAdmin();
          allow create: if isAuthenticated(); // Allow friends to send invites
        }

        match /messages/{messageId} {
          allow read, update, delete: if isOwner(userId) || isAdmin();
          allow create: if isAuthenticated();
        }
      }

      // Multiplayer Games
      match /games/{gameId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAdmin() || isPlayerInGame(resource.data) || (resource.data.p2 == null && isAuthenticated()); 
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.p1.uid == request.auth.uid);
      }
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
